<?xml version="1.0" encoding="utf-8"?>
<aas-template>
  <shell id="{{shell_id}}" idShort="{{id_short}}_stellenplan">
    <asset globalAssetId="{{asset_id}}" />
    <submodelRef>{{submodel_id}}</submodelRef>
  </shell>
  <submodel id="{{submodel_id}}" idShort="StellenplanProposal">
    <property idShort="tag">{{tag}}</property>
    <property idShort="canonicalTag">{{canonical_tag}}</property>
    <property idShort="functionCode">{{function_code}}</property>
    <property idShort="contextSummary">{{context_summary}}</property>
    <property idShort="recommendedAction">{{recommended_action}}</property>
    <property idShort="templateLanguage">{{ui_language}}</property>
    <property idShort="templateDisplayName">{{template_display_name}}</property>
    <property idShort="templateDisplayNameEn">{{template_display_name_en}}</property>
    <property idShort="templateDisplayNameDe">{{template_display_name_de}}</property>
    <property idShort="templateDisplayNameZh">{{template_display_name_zh}}</property>
  </submodel>
</aas-template>
